Port 22
AddressFamily any
ListenAddress 0.0.0.0

# Host keys (generated by ssh-keygen -A in Dockerfile)
HostKey /etc/ssh/ssh_host_rsa_key
HostKey /etc/ssh/ssh_host_ed25519_key

# Authentication: standard password (/etc/passwd:/etc/shadow), no PAM
PasswordAuthentication yes
PubkeyAuthentication no
UsePAM no

# Tunnel-only: no shell, no TTY, no X11
PermitTTY no
X11Forwarding no
AllowAgentForwarding no

# Only allow forwarding to MySQL inside Docker — nothing else
AllowTcpForwarding yes
PermitOpen db:3306

# Force exit immediately after successful auth (no interactive session)
ForceCommand /bin/false

# Logging
SyslogFacility AUTH
LogLevel INFO
