# MySQL root password — required for bundled MySQL and phpMyAdmin auto-login
MYSQL_ROOT_PASSWORD=change_me

# Public URL of this installation (no trailing slash) — required for phpMyAdmin sub-path routing
# Example: https://repo.yourdomain.com   or   http://localhost:8088
LTPDA_PUBLIC_URL=https://repo.yourdomain.com

# Optional: override the admin database name (default: ltpda_admin)
# ADMIN_DB=ltpda_admin
